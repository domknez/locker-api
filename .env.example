# Postgres
POSTGRES_USER=parcel
POSTGRES_PASSWORD=parcel
POSTGRES_DB=parcel
POSTGRES_PORT=5432

# API
API_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO

# Auth (any non-empty string; required for write endpoints)
API_BEARER_TOKEN=dev-secret-change-me

# Nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim requires an identifying User-Agent with a real contact (rejects generic ones).
NOMINATIM_USER_AGENT=ParcelLockerService/0.1 (your.email@example.com)
NOMINATIM_TIMEOUT_SECONDS=5

# Parcel submission window
PARCEL_SUBMISSION_TTL_HOURS=48
