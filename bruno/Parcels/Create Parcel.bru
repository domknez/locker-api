meta {
  name: Create Parcel
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/parcels
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "sender": "Alice",
    "receiver": "Bob",
    "size": "M",
    "submitted_at": "2026-05-10T10:00:00+02:00"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("lastParcelId", res.body.id);
  }
}

assert {
  res.status: eq 201
  res.body.state: eq ASSIGNED
  res.body.slot_id: isDefined
}
